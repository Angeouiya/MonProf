# Runtime Vercel / Prisma via Supabase pooler transaction mode.
# Ajouter pgbouncer=true et connection_limit=1 pour Prisma en environnement serverless.
DATABASE_URL="postgresql://competence_app.PROJECT_REF:PASSWORD@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1&schema=competence"

# Connexion directe ou pooler session mode pour Prisma db push / migrations.
DIRECT_URL="postgresql://competence_app.PROJECT_REF:PASSWORD@aws-1-eu-west-2.pooler.supabase.com:5432/postgres?sslmode=require&schema=competence"

NEXTAUTH_SECRET="change-me"
NEXT_PUBLIC_APP_URL="https://votre-domaine.ci"

# Scheduler Vercel Cron / cron externe
CRON_SECRET="change-me-cron-secret"

# Email transactionnel via Resend
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Compétence <notifications@votre-domaine.ci>"

# SMS via Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v20.0"
