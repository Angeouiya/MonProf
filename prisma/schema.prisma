model BookingRescheduleRequest {
  id                      String                  @id @default(cuid())
  bookingId               String
  teacherId               String
  clientId                String
  requestedBy             RescheduleRequestActor  @default(CLIENT)
  oldScheduledDate        DateTime?
  oldScheduledTime        String?
  proposedDate            DateTime
  proposedTime            String
  reason                  String?
  status                  RescheduleRequestStatus @default(PAYMENT_PENDING)
  feeWindow               String
  feeBaseAmount           Int                     @default(0)
  feeRate                 Int                     @default(0)
  feeAmount               Int                     @default(0)
  feeTeacherRate          Int                     @default(0)
  feeTeacherAmount        Int                     @default(0)
  feePlatformRate         Int                     @default(0)
  feePlatformAmount       Int                     @default(0)
  paymentServiceFeeRate   Int                     @default(0)
  paymentServiceFeeAmount Int                     @default(0)
  paymentServiceFeeLabel  String?
  totalToPay              Int                     @default(0)
  paydunyaToken           String?                 @unique
  paydunyaCheckoutUrl     String?
  paydunyaStatus          String?
  paydunyaReceiptUrl      String?
  paydunyaVerifiedAt      DateTime?
  paydunyaLastCheckedAt   DateTime?
  paydunyaFailureReason   String?
  paydunyaLastPayload     String?
