// Compétence - Plateforme de réservation de cours à domicile et en ligne
// Côte d'Ivoire

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// UTILISATEURS (Client + Admin seulement — pas de compte prof)
// ============================================================
model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  name                   String
  phone                  String?
  passwordHash           String
  role                   UserRole            @default(CLIENT)
  commune                String?
  quartier               String?
  avatarUrl              String?
  adminTeamRole          AdminTeamRole?
  adminAccountStatus     AdminAccountStatus?
  adminPermissions       Json?
  adminAccessEnabled     Boolean             @default(true)
  adminLastLoginAt       DateTime?
  adminPasswordChangedAt DateTime?
  adminCreatedById       String?
  adminSuspendedAt       DateTime?
  adminSuspensionReason  String?
  adminDeletedAt         DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  bookings                      Booking[]
  reviews                       Review[]
  disputes                      Dispute[]                  @relation("DisputeOpener")
  notifications                 Notification[]
  adminNotificationsSent        Notification[]             @relation("NotificationAdminSender")
  handledMessages               ContactMessage[]           @relation("HandledBy")
  teacherTasksCreated           TeacherTask[]              @relation("TeacherTaskCreator")
  teacherWarningsCreated        TeacherWarning[]           @relation("TeacherWarningCreator")
  teacherSanctionsCreated       TeacherSanction[]          @relation("TeacherSanctionCreator")
  teacherReplacementsCreated    TeacherReplacement[]       @relation("TeacherReplacementCreator")
  reviewsHandled                Review[]                   @relation("ReviewAdminReviewer")
  actionLogs                    AdminActionLog[]           @relation("AdminActionActor")
  clientCommunications          ClientCommunication[]      @relation("ClientCommunicationClient")
  clientCommunicationsSent      ClientCommunication[]      @relation("ClientCommunicationSender")
  clientRefundRequests          ClientRefundRequest[]      @relation("ClientRefundRequestClient")
  clientRescheduleRequests      BookingRescheduleRequest[] @relation("ClientRescheduleRequestClient")
  teacherPayoutsCreated         TeacherPayoutRecord[]      @relation("TeacherPayoutCreator")
  teacherPayoutRequestsReviewed TeacherPayoutRequest[]     @relation("TeacherPayoutRequestReviewer")
  teacherAdminMessagesSent      TeacherAdminMessage[]      @relation("TeacherAdminMessageAdminSender")
  passwordResetTokens           PasswordResetToken[]
  communicationCampaigns        CommunicationCampaign[]    @relation("CommunicationCampaignCreator")
  webPushSubscriptions          WebPushSubscription[]

  @@index([role])
  @@index([adminTeamRole, adminAccountStatus])
}

enum UserRole {
  CLIENT
  ADMIN
}

enum AdminTeamRole {
  OWNER
  SUPER_ADMIN
  OPERATIONS
  FINANCE
  SUPPORT
  QUALITY
  CONTENT
  OBSERVER
}

enum AdminAccountStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

// ============================================================
// RÉFÉRENTIELS
// ============================================================
model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())

  teachers TeacherSubject[]
}

model Level {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())

  teachers TeacherLevel[]
}

model Commune {
  id                   String                @id @default(cuid())
  name                 String                @unique
  slug                 String?               @unique
  zone                 String? // Région ou district administratif
  countryCode          String                @default("CI")
  transportClass       CommuneTransportClass @default(INTERIOR)
  transportFeeOverride Int?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt

  teachers TeacherZone[]
  quarters CommuneQuarter[]

  @@index([isActive, name])
  @@index([transportClass, isActive])
}

model CommuneQuarter {
  id        String   @id @default(cuid())
  communeId String
  name      String
  slug      String
  aliases   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commune Commune @relation(fields: [communeId], references: [id], onDelete: Cascade)

  @@unique([communeId, name])
  @@unique([communeId, slug])
  @@index([communeId, isActive, name])
}

enum CommuneTransportClass {
  GRAND_ABIDJAN
  PERI_URBAN
  INTERIOR
}

// ============================================================
// PROFESSEUR (fiche interne gérée par l'admin)
// ============================================================
model Teacher {
  id                     String             @id @default(cuid())
  // Identité
  fullName               String
  professionalName       String?
  photoUrl               String?
  phone                  String
  email                  String?
  commune                String?
  quartier               String?
  addressHint            String?
  // Accès léger à la plateforme professeur, activé uniquement par l'admin
  portalAccessEnabled    Boolean            @default(false)
  portalPhone            String?            @unique
  portalPasswordHash     String?
  portalLastLoginAt      DateTime?
  defaultPayoutMethod    PaymentMethod?
  defaultPayoutPhone     String?
  payoutInstructions     String?
  // Pédagogie
  jobTitle               String
  bio                    String
  experienceYears        Int                @default(0)
  diploma                String?
  cvUrl                  String?
  careerSummary          String?
  skills                 String?
  workHistory            String?
  certifications         String?
  teachingAchievements   String?
  learnersCoached        Int                @default(0)
  profileType            TeacherProfileType @default(ENSEIGNANT)
  // Statut & visibilité
  status                 TeacherStatus      @default(PENDING)
  featured               Boolean            @default(false)
  qualityScore           Int                @default(85)
  lastActivityAt         DateTime?
  operationalComment     String?
  adminRating            Float              @default(0) // 0..5, note plateforme/admin
  adminRatingNote        String?
  adminRatingPublic      Boolean            @default(true)
  adminRatingUpdatedAt   DateTime?
  adminRatingUpdatedById String?
  // Évaluation interne (gérée par admin)
  rating                 Float              @default(0) // 0..5
  ratingCount            Int                @default(0)
  // Badges
  badgeVerified          Boolean            @default(true)
  badgeRecommended       Boolean            @default(false)
  badgeNew               Boolean            @default(true)
  badgePopular           Boolean            @default(false)
  badgePremium           Boolean            @default(false)
  internalNote           String?
  // Format
  offersHome             Boolean            @default(true)
  offersOnline           Boolean            @default(true)
  offersGroup            Boolean            @default(false)
  // Tarification (FCFA)
  pricePerHour           Int                @default(10000)
  pricePerSession        Int                @default(10000)
  pricePack4             Int                @default(38000)
  pricePack8             Int                @default(72000)
  commissionRate         Int                @default(30) // %
  pricingTier            PricingTier        @default(STANDARD)
  // Disponibilités (JSON: {mon:{morning,afternoon,evening}, ...})
  availability           String?
  // Métadonnées
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  subjects             TeacherSubject[]
  levels               TeacherLevel[]
  zones                TeacherZone[]
  bookings             Booking[]
  reviews              Review[]
  transactions         Transaction[]
  notifications        TeacherNotification[]
  missionLinks         TeacherMissionLink[]
  scheduleProposals    BookingScheduleProposal[]
  rescheduleRequests   BookingRescheduleRequest[]
  tasks                TeacherTask[]
  warnings             TeacherWarning[]
  sanctions            TeacherSanction[]
  oldReplacements      TeacherReplacement[]       @relation("OldTeacherReplacement")
  newReplacements      TeacherReplacement[]       @relation("NewTeacherReplacement")
  paymentAdjustments   TeacherPaymentAdjustment[]
  payoutRecords        TeacherPayoutRecord[]
  payoutRequests       TeacherPayoutRequest[]
  adminMessages        TeacherAdminMessage[]
  webPushSubscriptions WebPushSubscription[]
  bookingSessions      BookingSession[]           @relation("BookingSessionTeacher")
  proposedSessions     BookingSession[]           @relation("BookingSessionProposedTeacher")

  @@index([status])
  @@index([featured])
  @@index([portalAccessEnabled])
}

// Photos professeur persistantes. Les fonctions Vercel ne peuvent pas écrire
// dans public/ en production, donc les images optimisées sont servies depuis la base.
model TeacherPhotoAsset {
  id          String   @id @default(cuid())
  contentType String   @default("image/webp")
  data        Bytes
  size        Int
  width       Int
  height      Int
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// Le CV source reste privé et n'est servi qu'aux administrateurs authentifiés.
model TeacherCvAsset {
  id           String   @id @default(cuid())
  originalName String
  contentType  String
  data         Bytes
  size         Int
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
  TEMPORARILY_SUSPENDED
  PERMANENTLY_SUSPENDED
  OBSERVATION
  REPLACEABLE
  PRIORITY
  BLACKLISTED
}

enum TeacherProfileType {
  ENSEIGNANT
  ETUDIANT
  REPETITEUR
  FORMATEUR
  PROFESSIONNEL
}

enum PricingTier {
  STANDARD
  RECOMMENDED
  PREMIUM
  PROMOTIONAL
}

model TeacherSubject {
  teacherId String
  subjectId String
  isPrimary Boolean @default(false)
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([teacherId, subjectId])
}

model TeacherLevel {
  teacherId String
  levelId   String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  level     Level   @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@id([teacherId, levelId])
}

model TeacherZone {
  teacherId String
  communeId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  commune   Commune @relation(fields: [communeId], references: [id], onDelete: Cascade)

  @@id([teacherId, communeId])
}

// ============================================================
// RÉSERVATION (Booking)
// ============================================================
model Booking {
  id                                String         @id @default(cuid())
  reference                         String         @unique // MP-XXXX
  clientId                          String
  teacherId                         String
  // Détails cours
  subjectName                       String
  levelName                         String
  objective                         String?
  clientType                        String?
  courseCategory                    String?
  schoolSystem                      String?
  preciseLevel                      String?
  courseCatalogId                   String?
  courseCatalogName                 String?
  schoolProgram                     String? // Programme scolaire (ex: "Programme officiel CI", "Edexcel", etc.)
  needDescription                   String? // Description du besoin
  courseFormat                      CourseFormat
  groupType                         GroupType      @default(INDIVIDUAL)
  participantsCount                 Int            @default(1)
  commune                           String?
  quartier                          String?
  addressHint                       String?
  onlineLink                        String?
  // Créneau
  preferredDays                     String // JSON: ["samedi","dimanche"]
  preferredTime                     String // "15h-17h"
  startDate                         DateTime? // Date de début souhaitée
  scheduledDate                     DateTime?
  scheduledTime                     String?
  sessionsCount                     Int            @default(1)
  packType                          PackType       @default(SINGLE)
  message                           String?
  // Montants (FCFA)
  unitPrice                         Int
  totalPrice                        Int
  priceTierKey                      String?
  courseAmount                      Int            @default(0)
  commissionRate                    Int            @default(30)
  commissionAmount                  Int            @default(0)
  teacherRate                       Int            @default(70)
  teacherPayoutAmount               Int            @default(0)
  transportFee                      Int            @default(0)
  transportFeeKey                   String?
  materialFee                       Int            @default(0)
  discountAmount                    Int            @default(0)
  paymentServiceFeeRate             Int            @default(0) // basis points, ex: 300 = 3%
  paymentServiceFeeAmount           Int            @default(0)
  paymentServiceFeeLabel            String?
  totalClientPays                   Int            @default(0)
  totalTeacherReceives              Int            @default(0)
  isQuoteOnly                       Boolean        @default(false)
  pricingSnapshot                   String?
  teacherNetAmount                  Int            @default(0)
  teacherPaidAmount                 Int            @default(0)
  // Statuts
  status                            BookingStatus  @default(PENDING_PAYMENT)
  paymentStatus                     PaymentStatus  @default(FAILED)
  paymentMethod                     PaymentMethod?
  // PayDunya anti-fraude et rapprochement serveur-à-serveur
  paydunyaToken                     String?        @unique
  paydunyaCheckoutUrl               String?
  paydunyaStatus                    String?
  paydunyaReceiptUrl                String?
  paydunyaVerifiedAt                DateTime?
  paydunyaLastCheckedAt             DateTime?
  paydunyaFailureReason             String?
  paydunyaLastPayload               String?
  // Méta
  createdAt                         DateTime       @default(now())
  updatedAt                         DateTime       @updatedAt
  confirmedAt                       DateTime?
  assignedAt                        DateTime?
  courseDoneAt                      DateTime?
  clientValidatedAt                 DateTime?
  teacherPaidAt                     DateTime?
  cancelledAt                       DateTime?
  cancelledBy                       String?
  cancellationReason                String?
  cancellationDetail                String?
  cancellationWindow                String?
  cancellationFeeRate               Int            @default(0)
  cancellationFeeAmount             Int            @default(0)
  cancellationPenaltyTeacherRate    Int            @default(0)
  cancellationPenaltyTeacherAmount  Int            @default(0)
  cancellationPenaltyPlatformRate   Int            @default(0)
  cancellationPenaltyPlatformAmount Int            @default(0)
  cancellationRefundAmount          Int            @default(0)

  client                    User                       @relation(fields: [clientId], references: [id])
  teacher                   Teacher                    @relation(fields: [teacherId], references: [id])
  transactions              Transaction[]
  reviews                   Review[]
  disputes                  Dispute[]
  teacherTasks              TeacherTask[]
  teacherWarnings           TeacherWarning[]
  teacherSanctions          TeacherSanction[]
  replacements              TeacherReplacement[]
  clientCommunications      ClientCommunication[]
  clientRefundRequests      ClientRefundRequest[]
  teacherPaymentAdjustments TeacherPaymentAdjustment[]
  teacherPayoutAllocations  TeacherPayoutAllocation[]
  missionLinks              TeacherMissionLink[]
  scheduleProposals         BookingScheduleProposal[]
  rescheduleRequests        BookingRescheduleRequest[]
  teacherAdminMessages      TeacherAdminMessage[]
  sessions                  BookingSession[]

  @@index([clientId])
  @@index([teacherId])
  @@index([status])
}

// Une réservation de pack est payée en une fois, mais exploitée et comptabilisée
// séance par séance. Les champs financiers de Booking restent les agrégats.
model BookingSession {
  id                  String               @id @default(cuid())
  bookingId           String
  sequence            Int
  teacherId           String
  proposedTeacherId   String?
  scheduledDate       DateTime?
  scheduledTime       String?
  durationMinutes     Int                  @default(120)
  status              BookingSessionStatus @default(PLANNED)
  courseAmount        Int                  @default(0)
  commissionAmount    Int                  @default(0)
  teacherCourseAmount Int                  @default(0)
  transportFee        Int                  @default(0)
  teacherNetAmount    Int                  @default(0)
  releasedAmount      Int                  @default(0)
  paidAmount          Int                  @default(0)
  retainedAmount      Int                  @default(0)
  proposedDate        DateTime?
  proposedTime        String?
  unavailableReason   String?
  completedAt         DateTime?
  clientValidatedAt   DateTime?
  releasedAt          DateTime?
  paidAt              DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  booking           Booking                   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  teacher           Teacher                   @relation("BookingSessionTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  proposedTeacher   Teacher?                  @relation("BookingSessionProposedTeacher", fields: [proposedTeacherId], references: [id], onDelete: SetNull)
  payoutAllocations TeacherPayoutAllocation[]
  history           BookingSessionHistory[]
  disputes          Dispute[]

  @@unique([bookingId, sequence])
  @@index([bookingId, status])
  @@index([teacherId, status, scheduledDate])
  @@index([proposedTeacherId, status])
}

model BookingSessionHistory {
  id               String   @id @default(cuid())
  bookingSessionId String
  actorType        String
  actorId          String?
  action           String
  fromStatus       String?
  toStatus         String?
  oldTeacherId     String?
  newTeacherId     String?
  detail           String?
  createdAt        DateTime @default(now())

  bookingSession BookingSession @relation(fields: [bookingSessionId], references: [id], onDelete: Cascade)

  @@index([bookingSessionId, createdAt])
  @@index([actorType, actorId])
}

enum BookingSessionStatus {
  PLANNED
  TEACHER_CONFIRMED
  IN_PROGRESS
  AWAITING_CLIENT_CONFIRMATION
  RELEASED
  PARTIALLY_PAID
  PAID
  RESCHEDULE_PROPOSED
  REPLACEMENT_PROPOSED
  NEEDS_REPLACEMENT
  DISPUTED
  CANCELLED
  REFUNDED
}

enum CourseFormat {
  HOME
  ONLINE
}

enum GroupType {
  INDIVIDUAL
  SMALL_GROUP
}

enum PackType {
  SINGLE
  PACK_4
  PACK_8
  PACK_12
  EXAM_PREP
  CUSTOM
}

enum BookingStatus {
  PENDING_PAYMENT
  PAID
  PENDING_ADMIN_VALIDATION
  CONFIRMED
  ASSIGNED
  IN_PROGRESS
  COURSE_DONE
  PENDING_CLIENT_VALIDATION
  VALIDATED_BY_CLIENT
  PAYMENT_TO_RELEASE
  TEACHER_PAID
  DISPUTED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  FAILED
  RECEIVED
  BLOCKED
  VALIDATED
  TO_PAY_TEACHER
  TEACHER_PAID
  DISPUTED
  REFUND_PENDING
  PARTIAL_REFUND_PENDING
  REFUNDED
  PARTIALLY_REFUNDED
  RETAINED
}

enum PaymentMethod {
  WAVE
  ORANGE_MONEY
  MTN_MONEY
  MOOV_MONEY
  CARD
}

// ============================================================
// TRANSACTION (historique financier)
// ============================================================
model Transaction {
  id                  String          @id @default(cuid())
  reference           String          @unique // TX-XXXX
  bookingId           String
  teacherId           String
  rescheduleRequestId String?         @unique
  amount              Int // montant total concerné
  commission          Int
  teacherNet          Int
  type                TransactionType
  status              PaymentStatus   @default(BLOCKED)
  method              PaymentMethod?
  paidAt              DateTime?
  createdAt           DateTime        @default(now())

  booking           Booking                   @relation(fields: [bookingId], references: [id])
  teacher           Teacher                   @relation(fields: [teacherId], references: [id])
  rescheduleRequest BookingRescheduleRequest? @relation(fields: [rescheduleRequestId], references: [id], onDelete: SetNull)
}

enum TransactionType {
  CLIENT_PAYMENT
  RESCHEDULE_FEE
  TEACHER_PAYOUT
  REFUND
  COMMISSION
}

// ============================================================
// AVIS & LITIGES
// ============================================================
model Review {
  id           String            @id @default(cuid())
  clientId     String
  teacherId    String
  bookingId    String
  rating       Int // 1..5
  comment      String?
  published    Boolean           @default(true)
  adminStatus  ReviewAdminStatus @default(NEW)
  adminNote    String?
  reviewedAt   DateTime?
  reviewedById String?
  createdAt    DateTime          @default(now())

  client     User    @relation(fields: [clientId], references: [id])
  teacher    Teacher @relation(fields: [teacherId], references: [id])
  booking    Booking @relation(fields: [bookingId], references: [id])
  reviewedBy User?   @relation("ReviewAdminReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([adminStatus])
  @@index([teacherId, adminStatus])
}

enum ReviewAdminStatus {
  NEW
  TO_REVIEW
  CONTACT_CLIENT
  CONTACT_TEACHER
  WARNING_SENT
  RESOLVED
  ESCALATED
  DISMISSED
}

model Dispute {
  id               String        @id @default(cuid())
  bookingId        String
  bookingSessionId String?
  openedById       String
  reason           String
  description      String
  status           DisputeStatus @default(OPEN)
  resolution       String?
  createdAt        DateTime      @default(now())
  resolvedAt       DateTime?

  booking        Booking         @relation(fields: [bookingId], references: [id])
  bookingSession BookingSession? @relation(fields: [bookingSessionId], references: [id], onDelete: SetNull)
  openedBy       User            @relation("DisputeOpener", fields: [openedById], references: [id])

  @@index([bookingSessionId])
}

enum DisputeStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  REFUNDED
  REJECTED
}

// ============================================================
// NOTIFICATIONS
// ============================================================
model Notification {
  id            String                    @id @default(cuid())
  userId        String? // client ciblé, admin = null si broadcast admin
  title         String
  message       String
  type          String // NEW_BOOKING, PAYMENT_RECEIVED, etc.
  recipientType NotificationRecipientType @default(ADMIN)
  recipientName String?
  channel       NotificationChannel       @default(INTERNAL)
  status        NotificationStatus        @default(CREATED)
  priority      NotificationPriority      @default(NORMAL)
  read          Boolean                   @default(false)
  link          String?
  actionLabel   String?
  actionType    String?
  bookingId     String?
  teacherId     String?
  clientId      String?
  adminId       String?
  campaignId    String?
  sentAt        DateTime?
  readAt        DateTime?
  confirmedAt   DateTime?
  expiresAt     DateTime?
  response      String?
  createdAt     DateTime                  @default(now())

  user     User?                  @relation(fields: [userId], references: [id])
  admin    User?                  @relation("NotificationAdminSender", fields: [adminId], references: [id], onDelete: SetNull)
  campaign CommunicationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([recipientType, status, priority])
  @@index([bookingId])
  @@index([teacherId])
  @@index([clientId])
  @@index([campaignId])
}

model CommunicationCampaign {
  id              String                      @id @default(cuid())
  reference       String                      @unique
  title           String
  message         String
  audience        CommunicationAudience
  targetUserId    String?
  targetTeacherId String?
  channel         NotificationChannel         @default(INTERNAL)
  priority        NotificationPriority        @default(NORMAL)
  status          CommunicationCampaignStatus @default(DRAFT)
  recipientCount  Int                         @default(0)
  deliveredCount  Int                         @default(0)
  failedCount     Int                         @default(0)
  link            String?
  actionLabel     String?
  startsAt        DateTime?
  expiresAt       DateTime?
  sentAt          DateTime?
  createdById     String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  createdBy            User?                 @relation("CommunicationCampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)
  notifications        Notification[]
  teacherNotifications TeacherNotification[]

  @@index([status, createdAt])
  @@index([audience, createdAt])
  @@index([createdById])
}

enum CommunicationAudience {
  ONE_CLIENT
  ONE_TEACHER
  ALL_CLIENTS
  ALL_TEACHERS
  ALL_USERS
}

enum CommunicationCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PARTIAL
  FAILED
  CANCELLED
}

enum NotificationRecipientType {
  CLIENT
  TEACHER
  ADMIN
}

enum NotificationChannel {
  INTERNAL
  SMS
  WHATSAPP
  EMAIL
  BROWSER
  PWA
  MANUAL_CALL
  PRIVATE_LINK
}

enum NotificationStatus {
  CREATED
  SENT
  FAILED
  SEEN
  CONFIRMED
  EXPIRED
  RELAUNCHED
}

enum NotificationPriority {
  NORMAL
  IMPORTANT
  URGENT
  CRITICAL
}

// Un abonnement correspond à un navigateur/appareil. Les clients et les
// administrateurs utilisent userId ; l'espace professeur utilise teacherId.
model WebPushSubscription {
  id             String    @id @default(cuid())
  userId         String?
  teacherId      String?
  endpoint       String    @unique @db.Text
  p256dh         String    @db.Text
  auth           String    @db.Text
  expirationTime BigInt?
  userAgent      String?   @db.Text
  enabled        Boolean   @default(true)
  failureCount   Int       @default(0)
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@index([teacherId, enabled])
  @@index([enabled, updatedAt])
}

// L'outbox garantit qu'une notification métier validée en base n'est pas
// perdue si le provider push est momentanément indisponible.
model WebPushOutbox {
  id                    String                    @id @default(uuid()) @db.Uuid
  notificationId        String?                   @unique
  teacherNotificationId String?                   @unique
  recipientType         NotificationRecipientType
  targetUserId          String?
  targetTeacherId       String?
  title                 String
  message               String                    @db.Text
  link                  String?
  priority              NotificationPriority      @default(NORMAL)
  status                WebPushOutboxStatus       @default(PENDING)
  attempts              Int                       @default(0)
  nextAttemptAt         DateTime                  @default(now())
  processedAt           DateTime?
  lastError             String?                   @db.Text
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([status, nextAttemptAt])
  @@index([targetUserId, status])
  @@index([targetTeacherId, status])
}

enum WebPushOutboxStatus {
  PENDING
  PROCESSING
  SENT
  PARTIAL
  NO_SUBSCRIPTION
  FAILED
  DEAD
}

